namespace test.armor_setters

requires mod("Skyrim.esm")

# Every in-scope armor setter applied to Iron Helmet (EditorID
# `ArmorIronHelmet`, FormID 0x00012E4D).
#
# Out of scope today (no declared ARMO relation → no Mora-surface setter):
#   • set_enchantment
modify_iron_helmet(A):
    form/armor(A)
    A == @ArmorIronHelmet
    => set form/gold_value(A, 777)
    => set form/weight(A, 8.25)
    => set form/name(A, "Modified Iron Helmet")
    # Int literal: the runtime's apply_armor_field writes
    # `static_cast<uint32_t>(e.value)` directly, so a Float-valued patch
    # (as `2500.0` would produce) gets its IEEE-754 bits truncated to
    # zero when the int64 payload is reinterpreted. The YAML's declared
    # countable<Float> type also disagrees with the in-memory UInt32
    # layout — see tests/getters/test_armor_getters for the ESP-read
    # side of the same schema inconsistency.
    => set form/armor_rating(A, 2500)
    => add form/keyword(A, @MagicDisallowEnchanting)
