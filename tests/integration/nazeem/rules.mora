namespace test.nazeem

requires mod("Skyrim.esm")

# Every NPC's full name becomes "Nazeem".
# Exercises static patching of a scalar<String> field end-to-end (set
# form/name — backed by TESFullName → BSFixedString at the runtime).
everyone_is_nazeem(NPC):
    form/npc(NPC)
    => set form/name(NPC, "Nazeem")
