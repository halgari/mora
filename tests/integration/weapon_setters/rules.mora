namespace test.weapon_setters

requires mod("Skyrim.esm")

# Exercises every in-scope weapon setter verb, scoped to one well-known
# vanilla form — Iron Sword (EditorID `IronSword`, FormID 0x00012EB7).
# Each effect picks a distinct expected value so check.sh can assert each
# field independently against the harness's weapons.jsonl dump.
#
# Out of scope today (no declared WEAP relation → no Mora-surface setter):
#   • set_stagger / set_range_min / set_range_max / set_crit_damage
#   • set_enchantment
modify_iron_sword(W):
    form/weapon(W)
    W == @IronSword
    => set form/damage(W, 42)
    => set form/gold_value(W, 999)
    => set form/weight(W, 3.5)
    => set form/name(W, "Modified Iron Sword")
    => set form/speed(W, 2.0)
    => set form/reach(W, 1.25)
    => add form/keyword(W, @MagicDisallowEnchanting)
