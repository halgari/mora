namespace my_mod.bounty

use ref :as r
use form :as f

# Derive which player-victim pairs qualify for a bounty.
# (Gold payment via player/add removed: :Gold has no field mapping —
#  domain gap, not a vectorizer gap.)
on bandit_bounty(Player, Victim):
    event/killed(Victim, Player)
    r/is_player(Player)
    r/is_npc(Victim)
    r/base_form(Victim, Base)
    f/faction(Base, @BanditFaction)
    r/level(Victim, VL)
    r/level(Player, PL)
