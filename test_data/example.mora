namespace test.example

requires mod("Skyrim.esm")

# Derived rule: all NPCs in the Bandit faction
bandit(NPC):
    form/npc(NPC)
    form/faction(NPC, @BanditFaction)

# Tag all bandits with a keyword
tag_bandits(NPC):
    bandit(NPC)
    => add form/keyword(NPC, @ActorTypeNPC)

# Silver weapons (not greatswords) get extra damage
silver_weapons(Weapon):
    form/weapon(Weapon)
    form/keyword(Weapon, @WeapMaterialSilver)
    not form/keyword(Weapon, @WeapTypeGreatsword)
    => add form/keyword(Weapon, @WeapMaterialSilver)

# All iron weapons
iron_weapons(Weapon):
    form/weapon(Weapon)
    form/keyword(Weapon, @WeapMaterialIron)
    => add form/keyword(Weapon, @WeapMaterialIron)

# High-level bandits (level 20+)
elite_bandits(NPC):
    bandit(NPC)
    form/base_level(NPC, Level)
    Level >= 20
    => add form/keyword(NPC, @ActorTypeNPC)
